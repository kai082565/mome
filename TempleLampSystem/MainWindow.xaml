<Window x:Class="TempleLampSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TempleLampSystem.Views"
        Title="鎰翔科技 - 點燈管理系統"
        Height="800"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 頂部標題區 - 鎰翔水墨殿堂 -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource GoldDarkBrush}"
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 頂部金飾線 -->
                <Border Height="4" Background="{StaticResource GoldGradient}"/>

                <!-- 主標題區 -->
                <Border Grid.Row="1" Padding="25,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左側：系統標題 + 鎰翔品牌 -->
                        <StackPanel Orientation="Horizontal">
                            <!-- 品牌印章圓形 -->
                            <Border Background="#0D1B2A" CornerRadius="25" Padding="8" Margin="0,0,15,0"
                                    BorderBrush="{StaticResource GoldBrush}" BorderThickness="2">
                                <TextBlock Text="&#x2726;"
                                           FontSize="26"
                                           Foreground="#C8A84B"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="點燈管理系統"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           Foreground="#E5CA7A"
                                           FontFamily="{StaticResource PrimaryFont}"/>
                                <!-- 鎰翔科技品牌標語 -->
                                <StackPanel Orientation="Horizontal" Margin="2,3,0,0">
                                    <TextBlock Text="鎰翔科技"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="#C8A84B"
                                               FontFamily="{StaticResource PrimaryFont}"/>
                                    <TextBlock Text=" ・ 科技如詩，為你譜寫"
                                               FontSize="11"
                                               Foreground="#B8A880"
                                               Opacity="0.75"
                                               FontFamily="{StaticResource PrimaryFont}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- 中間：宮廟牌匾 -->
                        <Border Grid.Column="1"
                                BorderBrush="#4A3508"
                                BorderThickness="1.5"
                                Padding="3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="10,0">
                            <Border BorderBrush="#C8A84B" BorderThickness="1" Padding="18,7">
                                <StackPanel HorizontalAlignment="Center">
                                    <!-- 上方裝飾線 -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                        <TextBlock Text="&#x2726;" Foreground="#C8A84B" FontSize="11" VerticalAlignment="Center"/>
                                        <Rectangle Height="1" Width="55" Fill="#7A6020" VerticalAlignment="Center" Margin="6,0"/>
                                        <TextBlock Text="&#x25C6;" Foreground="#9A7C2A" FontSize="9" VerticalAlignment="Center"/>
                                        <Rectangle Height="1" Width="55" Fill="#7A6020" VerticalAlignment="Center" Margin="6,0"/>
                                        <TextBlock Text="&#x2726;" Foreground="#C8A84B" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- 廟名 -->
                                    <TextBlock Text="福　清　宮"
                                               FontSize="38"
                                               FontWeight="Bold"
                                               Foreground="#E5CA7A"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#C8A84B" BlurRadius="14" ShadowDepth="0" Opacity="0.6"/>
                                        </TextBlock.Effect>
                                    </TextBlock>

                                    <!-- 副標語 -->
                                    <TextBlock Text="敬神奉香　·　點燈祈福"
                                               FontSize="11"
                                               Foreground="#9A7C2A"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               HorizontalAlignment="Center"
                                               Margin="0,3,0,5"/>

                                    <!-- 下方裝飾線 -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#x2726;" Foreground="#C8A84B" FontSize="11" VerticalAlignment="Center"/>
                                        <Rectangle Height="1" Width="55" Fill="#7A6020" VerticalAlignment="Center" Margin="6,0"/>
                                        <TextBlock Text="&#x25C6;" Foreground="#9A7C2A" FontSize="9" VerticalAlignment="Center"/>
                                        <Rectangle Height="1" Width="55" Fill="#7A6020" VerticalAlignment="Center" Margin="6,0"/>
                                        <TextBlock Text="&#x2726;" Foreground="#C8A84B" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Border>

                        <!-- 右側：登入者、按鈕 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 登入者 -->
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock x:Name="LoginStaffText"
                                           FontSize="13" Foreground="#C8A84B"
                                           FontFamily="{StaticResource PrimaryFont}"/>
                            </StackPanel>

                            <!-- 管理員儀表板（僅管理員可見） -->
                            <Button x:Name="AdminDashboardButton"
                                    Content="管理員儀表板"
                                    Click="AdminDashboardButton_Click"
                                    FontSize="12"
                                    Foreground="#E5CA7A"
                                    Background="#1A2B3C"
                                    BorderBrush="{StaticResource GoldBrush}"
                                    BorderThickness="1"
                                    Padding="12,6"
                                    Margin="0,0,6,0"
                                    Cursor="Hand"
                                    FontFamily="{StaticResource PrimaryFont}"
                                    Visibility="Collapsed"/>

                            <!-- 匯入舊資料 -->
                            <Button x:Name="ImportDataButton"
                                    Content="匯入舊資料"
                                    Click="ImportDataButton_Click"
                                    FontSize="12"
                                    Foreground="#E5CA7A"
                                    Background="#1A2B3C"
                                    BorderBrush="{StaticResource GoldBrush}"
                                    BorderThickness="1"
                                    Padding="12,6"
                                    Margin="0,0,6,0"
                                    Cursor="Hand"
                                    FontFamily="{StaticResource PrimaryFont}"/>

                            <!-- 登出 -->
                            <Button x:Name="LogoutButton"
                                    Content="登出"
                                    Click="LogoutButton_Click"
                                    FontSize="12"
                                    Foreground="#E5CA7A"
                                    Background="#1A2B3C"
                                    BorderBrush="{StaticResource GoldBrush}"
                                    BorderThickness="1"
                                    Padding="12,6"
                                    Margin="0,0,12,0"
                                    Cursor="Hand"
                                    FontFamily="{StaticResource PrimaryFont}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 底部金飾線 -->
                <Border Grid.Row="2" Height="3" Background="{StaticResource GoldGradient}"/>
            </Grid>
        </Border>

        <!-- 主內容區 -->
        <Grid Grid.Row="1" Margin="15,18,15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側：客戶搜尋 -->
            <GroupBox Grid.Column="0" Header="客戶搜尋" Margin="5">
                <views:CustomerSearchView x:Name="CustomerSearchView"/>
            </GroupBox>

            <!-- 分隔線 -->
            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- 右側：點燈操作 -->
            <GroupBox Grid.Column="2" Header="點燈操作" Margin="5">
                <views:LampOrderView x:Name="LampOrderView"/>
            </GroupBox>
        </Grid>

        <!-- 底部狀態列 -->
        <Border Grid.Row="2"
                Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource GoldDarkBrush}"
                BorderThickness="0,2,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- 金飾線 -->
                <Border Height="2" Background="{StaticResource GoldGradient}"/>
                <StatusBar Grid.Row="1" Background="Transparent">
                    <StatusBarItem>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="OnlineIndicatorBorder"
                                    Width="12" Height="12"
                                    CornerRadius="6"
                                    Background="Gray"
                                    Margin="0,0,8,0"/>
                            <Ellipse x:Name="OnlineIndicator"
                                     Width="0" Height="0"
                                     Visibility="Collapsed"/>
                            <TextBlock x:Name="SyncStatusText" Text="檢查連線中..." FontWeight="SemiBold" Foreground="#C8A84B"/>
                        </StackPanel>
                    </StatusBarItem>
                    <Separator Background="{StaticResource GoldDarkBrush}" Opacity="0.5"/>
                    <StatusBarItem>
                        <TextBlock x:Name="PendingSyncText" Text="" Foreground="#8A7A60"/>
                    </StatusBarItem>
                    <StatusBarItem HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="鎰翔科技 &#x2726; " FontSize="11" Foreground="#9A7C2A" VerticalAlignment="Center" Opacity="0.8"/>
                            <TextBlock x:Name="CurrentTimeText" Text="" FontWeight="SemiBold" Foreground="#E5CA7A"/>
                        </StackPanel>
                    </StatusBarItem>
                </StatusBar>
            </Grid>
        </Border>
    </Grid>
</Window>
