<Window x:Class="TempleLampSystem.Views.SetupConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="鎰翔科技 - 初始設定精靈"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}">

    <StackPanel>

        <!-- 頂部標題列 -->
        <Border Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource GoldDarkBrush}"
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource GoldGradient}"/>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,16,0,14">
                    <TextBlock Text="&#x2726;" FontSize="18" Foreground="#C8A84B" HorizontalAlignment="Center"/>
                    <TextBlock Text="鎰翔科技" FontSize="20" FontWeight="Bold"
                               Foreground="#E5CA7A" HorizontalAlignment="Center"
                               FontFamily="{StaticResource PrimaryFont}" Margin="0,4,0,2"/>
                    <TextBlock Text="初始設定精靈" FontSize="13"
                               Foreground="#8A7A60" HorizontalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Row="2" Background="{StaticResource GoldGradient}"/>
            </Grid>
        </Border>

        <!-- 內容區 -->
        <StackPanel Margin="40,28,40,28">

            <TextBlock Text="請輸入宮廟基本資訊" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource SecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="設定完成後即可正式使用。" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- 宮廟名稱 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="宮廟名稱" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="（必填）" FontSize="11" Foreground="#C62828"
                           VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
            <TextBox x:Name="TempleNameBox" FontSize="15" Padding="10,8"
                     Margin="0,0,0,18" MaxLength="50"/>

            <!-- 宮廟地址 -->
            <TextBlock Text="宮廟地址" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="TempleAddressBox" FontSize="15" Padding="10,8"
                     Margin="0,0,0,18" MaxLength="100"/>

            <!-- 宮廟電話 -->
            <TextBlock Text="宮廟電話" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="TemplePhoneBox" FontSize="15" Padding="10,8"
                     Margin="0,0,0,20" MaxLength="30"/>

            <!-- 錯誤訊息 -->
            <TextBlock x:Name="ErrorText" Foreground="#C62828" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,12"
                       Visibility="Collapsed" TextWrapping="Wrap"/>

            <!-- 完成按鈕 -->
            <Button Content="完成設定" FontSize="15" FontWeight="Bold"
                    Padding="0,12" Style="{StaticResource PrimaryButton}"
                    Click="FinishButton_Click"/>

        </StackPanel>
    </StackPanel>
</Window>
