<Window x:Class="TempleLampSystem.Views.SetupConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="鎰翔科技 - 初始設定精靈"
        Width="520"
        Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頂部標題列 -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource GoldDarkBrush}"
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource GoldGradient}"/>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,16,0,14">
                    <TextBlock Text="&#x2726;" FontSize="18" Foreground="#C8A84B" HorizontalAlignment="Center"/>
                    <TextBlock Text="鎰翔科技" FontSize="20" FontWeight="Bold"
                               Foreground="#E5CA7A" HorizontalAlignment="Center"
                               FontFamily="{StaticResource PrimaryFont}" Margin="0,4,0,2"/>
                    <TextBlock x:Name="StepLabel" Text="步驟 1 / 2　－　宮廟資訊設定" FontSize="13"
                               Foreground="#8A7A60" HorizontalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Row="2" Background="{StaticResource GoldGradient}"/>
            </Grid>
        </Border>

        <!-- 步驟 1：宮廟資訊 -->
        <StackPanel x:Name="Page1" Grid.Row="1" Margin="40,28,40,24">
            <TextBlock Text="歡迎使用點燈管理系統" FontSize="17" FontWeight="Bold"
                       Foreground="{StaticResource SecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="請輸入宮廟基本資訊，設定完成後即可正式使用。" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap"
                       Margin="0,0,0,28"/>

            <!-- 宮廟名稱 -->
            <StackPanel Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="宮廟名稱" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="（必填）" FontSize="11" Foreground="#C62828"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </StackPanel>
            <TextBox x:Name="TempleNameBox" FontSize="15" Padding="10,8" Margin="0,0,0,18"
                     MaxLength="50"/>

            <!-- 地址 -->
            <TextBlock Text="宮廟地址" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="TempleAddressBox" FontSize="15" Padding="10,8" Margin="0,0,0,18"
                     MaxLength="100"/>

            <!-- 電話 -->
            <TextBlock Text="宮廟電話" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="TemplePhoneBox" FontSize="15" Padding="10,8" Margin="0,0,0,24"
                     MaxLength="30"/>

            <!-- 錯誤訊息 -->
            <TextBlock x:Name="Page1Error" Foreground="#C62828" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,12" Visibility="Collapsed"/>

            <!-- 下一步 -->
            <Button Content="下一步　→" FontSize="15" FontWeight="Bold"
                    Padding="0,12" Style="{StaticResource PrimaryButton}"
                    Click="NextButton_Click"/>
        </StackPanel>

        <!-- 步驟 2：Supabase 設定 -->
        <StackPanel x:Name="Page2" Grid.Row="1" Margin="40,28,40,24" Visibility="Collapsed">
            <TextBlock Text="雲端同步設定（Supabase）" FontSize="17" FontWeight="Bold"
                       Foreground="{StaticResource SecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Margin="0,0,0,24">
                請登入 supabase.com 建立新專案，並在「Project Settings → API」頁面<LineBreak/>
                複製 Project URL 和 anon public key 填入下方。
            </TextBlock>

            <!-- Supabase URL -->
            <TextBlock Text="Supabase Project URL" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="SupabaseUrlBox" FontSize="13" Padding="10,8" Margin="0,0,0,4"
                     FontFamily="Consolas, Courier New"/>
            <TextBlock Text="範例：https://abcdefghijklmnop.supabase.co" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

            <!-- Anon Key -->
            <TextBlock Text="Supabase Anon Key" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="SupabaseKeyBox" FontSize="12" Padding="10,8" Margin="0,0,0,4"
                     FontFamily="Consolas, Courier New"
                     TextWrapping="Wrap" Height="60"
                     VerticalScrollBarVisibility="Auto"
                     AcceptsReturn="False"/>
            <TextBlock Text="在 Supabase 後台 Project Settings → API → Project API keys → anon public" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,18"
                       TextWrapping="Wrap"/>

            <!-- 錯誤 / 狀態訊息 -->
            <TextBlock x:Name="Page2Error" Foreground="#C62828" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,6" Visibility="Collapsed"/>
            <TextBlock x:Name="TestStatusText" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,12" Visibility="Collapsed"/>

            <!-- 按鈕列 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                <Button Content="← 上一步" FontSize="13" Padding="20,10"
                        Margin="0,0,10,0" Click="BackButton_Click"/>
                <Button x:Name="TestButton" Content="測試連線" FontSize="13" Padding="20,10"
                        Margin="0,0,10,0" Click="TestButton_Click"/>
                <Button Content="完成設定" FontSize="15" FontWeight="Bold"
                        Padding="24,10" Style="{StaticResource PrimaryButton}"
                        Click="FinishButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
