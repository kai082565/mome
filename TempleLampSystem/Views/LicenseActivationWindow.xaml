<Window x:Class="TempleLampSystem.Views.LicenseActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="鎰翔科技 - 軟體授權驗證"
        Width="480"
        Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}">

    <StackPanel>
        <!-- 頂部標題列 -->
        <Border Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource GoldDarkBrush}"
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource GoldGradient}"/>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,16,0,14">
                    <TextBlock Text="&#x2726;" FontSize="18" Foreground="#C8A84B" HorizontalAlignment="Center"/>
                    <TextBlock Text="鎰翔科技" FontSize="20" FontWeight="Bold"
                               Foreground="#E5CA7A" HorizontalAlignment="Center"
                               FontFamily="{StaticResource PrimaryFont}" Margin="0,4,0,2"/>
                    <TextBlock Text="軟體授權驗證" FontSize="13"
                               Foreground="#8A7A60" HorizontalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Row="2" Background="{StaticResource GoldGradient}"/>
            </Grid>
        </Border>

        <!-- 內容區 -->
        <StackPanel Margin="36,24,36,20">

            <!-- 說明 -->
            <TextBlock TextWrapping="Wrap" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20">
                此電腦尚未啟用授權。請將下方「機器碼」提供給鎰翔科技，取得授權金鑰後輸入即可啟用。
            </TextBlock>

            <!-- 機器碼 -->
            <TextBlock Text="本機機器碼" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Background="White" CornerRadius="4,0,0,4"
                        BorderBrush="{StaticResource GoldDarkBrush}" BorderThickness="1,1,0,1"
                        Padding="10,8">
                    <TextBlock x:Name="MachineIdText" FontSize="16" FontWeight="Bold"
                               FontFamily="Consolas, Courier New"
                               Foreground="{StaticResource SecondaryBrush}"/>
                </Border>
                <Button x:Name="CopyButton" Grid.Column="1"
                        Content="複製" FontSize="13" Padding="16,8"
                        BorderThickness="0"
                        Click="CopyButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Background" Value="{StaticResource GoldBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- 授權金鑰輸入 -->
            <TextBlock Text="授權金鑰" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="LicenseKeyBox"
                     FontSize="15" Padding="10,8"
                     FontFamily="Consolas, Courier New"
                     CharacterCasing="Upper"
                     MaxLength="9"
                     Margin="0,0,0,8"/>
            <TextBlock Text="格式：XXXX-XXXX" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

            <!-- 錯誤訊息 -->
            <TextBlock x:Name="ErrorText" Foreground="#C62828" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,14"
                       Visibility="Collapsed"/>

            <!-- 啟用按鈕 -->
            <Button Content="啟用授權" FontSize="15" FontWeight="Bold"
                    Padding="0,12"
                    Style="{StaticResource PrimaryButton}"
                    Click="ActivateButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
