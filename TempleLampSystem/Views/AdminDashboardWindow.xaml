<Window x:Class="TempleLampSystem.Views.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:TempleLampSystem.Converters"
        Title="管理員儀表板"
        Height="720"
        Width="1100"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頂部標題 -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource GoldDarkBrush}"
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Height="4" Background="{StaticResource GoldGradient}"/>
                <Border Grid.Row="1" Padding="20,12">
                    <TextBlock Text="管理員儀表板" FontSize="22" FontWeight="Bold"
                               Foreground="#FFD700" FontFamily="{StaticResource PrimaryFont}"/>
                </Border>
                <Border Grid.Row="2" Height="3" Background="{StaticResource GoldGradient}"/>
            </Grid>
        </Border>

        <!-- 主內容（TabControl） -->
        <TabControl Grid.Row="1" Margin="15,12,15,12"
                    Background="Transparent"
                    BorderBrush="{StaticResource GoldDarkBrush}">

            <!-- ===== 點燈統計 TabItem ===== -->
            <TabItem Header="點燈統計" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 日期篩選 -->
                    <Border Grid.Row="0" Background="#FFF8ED" CornerRadius="8" Padding="16,10"
                            BorderBrush="{StaticResource GoldDarkBrush}" BorderThickness="1" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="日期範圍：" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,10,0"/>
                            <DatePicker x:Name="StartDatePicker" FontSize="13" Margin="0,0,8,0"
                                        SelectedDateChanged="DateFilter_Changed"/>
                            <TextBlock Text="～" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker x:Name="EndDatePicker" FontSize="13" Margin="0,0,16,0"
                                        SelectedDateChanged="DateFilter_Changed"/>
                            <Button Content="篩選" Padding="16,6" FontSize="13"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="FilterButton_Click"/>
                            <Button Content="今天" Padding="16,6" FontSize="13"
                                    Margin="8,0,0,0" Click="TodayButton_Click"/>
                            <Button Content="本月" Padding="16,6" FontSize="13"
                                    Margin="8,0,0,0" Click="ThisMonthButton_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- 統計摘要卡片 -->
                    <Border Grid.Row="1" Background="#FFF8ED" CornerRadius="8" Padding="16,10"
                            BorderBrush="{StaticResource GoldDarkBrush}" BorderThickness="1" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="總點燈數" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="TotalOrdersText" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource SecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="總金額" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="TotalAmountText" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource GoldDarkBrush}"/>
                            </StackPanel>
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,32,0"/>
                            <!-- 人員摘要由 ItemsControl 動態產生 -->
                            <ItemsControl x:Name="StaffSummaryControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,24,0">
                                            <TextBlock Text="{Binding StaffName}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Count}" FontSize="20" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- 點燈紀錄 DataGrid -->
                    <Border Grid.Row="2" Background="White" CornerRadius="8"
                            BorderBrush="{StaticResource GoldDarkBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 篩選列 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8">
                                <TextBlock Text="篩選 " FontSize="13" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <ComboBox x:Name="StaffFilterCombo" Width="110" FontSize="13"
                                          Margin="6,0" SelectionChanged="Filter_SelectionChanged"
                                          ToolTip="按操作人員篩選"/>
                                <ComboBox x:Name="TempleFilterCombo" Width="100" FontSize="13"
                                          Margin="6,0" SelectionChanged="Filter_SelectionChanged"
                                          ToolTip="按廟別篩選"/>
                                <ComboBox x:Name="LampFilterCombo" Width="100" FontSize="13"
                                          Margin="6,0" SelectionChanged="Filter_SelectionChanged"
                                          ToolTip="按燈種篩選"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      x:Name="OrdersDataGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#FFFAF0"
                                      FontSize="13"
                                      Margin="0,0,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="點燈時間" Binding="{Binding CreatedAt, StringFormat=MM/dd HH:mm}" Width="100"/>
                                    <DataGridTextColumn Header="操作人員" Binding="{Binding StaffName}" Width="80"/>
                                    <DataGridTextColumn Header="客戶" Binding="{Binding CustomerName}" Width="80"/>
                                    <DataGridTextColumn Header="燈種" Binding="{Binding LampName}" Width="100"/>
                                    <DataGridTextColumn Header="廟別" Binding="{Binding Temple}" Width="80"/>
                                    <DataGridTextColumn Header="神明" Binding="{Binding Deity}" Width="80"/>
                                    <DataGridTextColumn Header="年度" Binding="{Binding Year}" Width="55"/>
                                    <DataGridTextColumn Header="金額" Binding="{Binding Price, StringFormat=${0:N0}}" Width="70"/>
                                    <DataGridTextColumn Header="起始日" Binding="{Binding StartDate, StringFormat=MM/dd}" Width="70"/>
                                    <DataGridTextColumn Header="到期日" Binding="{Binding EndDate, StringFormat=yyyy/MM/dd}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== 帳號管理 TabItem ===== -->
            <TabItem Header="帳號管理" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左側：人員列表 -->
                    <Border Grid.Column="0" Background="White" CornerRadius="8"
                            BorderBrush="{StaticResource GoldDarkBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Padding="12,10" Background="#FFF8ED" CornerRadius="8,8,0,0">
                                <TextBlock Text="工作人員列表" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryBrush}"/>
                            </Border>
                            <ListBox Grid.Row="1" x:Name="StaffListBox"
                                     SelectionChanged="StaffListBox_SelectionChanged"
                                     FontSize="14" Margin="4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text=" [管理員]" FontSize="12"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"/>
                                                <TextBlock Text=" [停用]" FontSize="12"
                                                           Foreground="Gray"
                                                           Visibility="{Binding IsInactive, Converter={StaticResource BoolToVisibility}}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- 右側：操作區 -->
                    <StackPanel Grid.Column="2">
                        <!-- 新增人員 -->
                        <Border Background="White" CornerRadius="8" Padding="20"
                                BorderBrush="{StaticResource GoldDarkBrush}" BorderThickness="1" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="新增工作人員" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryBrush}" Margin="0,0,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="姓名" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="NewNameTextBox"
                                             FontSize="14" Padding="8,6" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="密碼" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,0,10"/>
                                    <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="NewPasswordBox"
                                                 FontSize="14" Padding="8,6" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="角色" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,0,14"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="NewRoleCombo"
                                              FontSize="13" Padding="8,6" Margin="0,0,0,14">
                                        <ComboBoxItem Content="工作人員" IsSelected="True"/>
                                        <ComboBoxItem Content="管理員"/>
                                    </ComboBox>

                                    <TextBlock Grid.Row="3" Grid.Column="0"/>
                                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="新增" Padding="20,8" FontSize="14"
                                                Style="{StaticResource SuccessButton}"
                                                Click="AddStaffButton_Click"/>
                                        <TextBlock x:Name="AddStaffErrorText" Foreground="Red" FontSize="12"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 選取人員的操作 -->
                        <Border x:Name="SelectedStaffPanel" Background="White" CornerRadius="8" Padding="20"
                                BorderBrush="{StaticResource GoldDarkBrush}" BorderThickness="1"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="SelectedStaffTitle" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryBrush}" Margin="0,0,0,14"/>

                                <!-- 重設密碼 -->
                                <TextBlock Text="重設密碼" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <PasswordBox x:Name="ResetPasswordBox" Width="200" FontSize="14"
                                                 Padding="8,6" Margin="0,0,10,0"/>
                                    <Button Content="重設" Padding="16,6" FontSize="13"
                                            Click="ResetPasswordButton_Click"/>
                                </StackPanel>

                                <!-- 啟用/停用 -->
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="ToggleActiveButton"
                                            Padding="20,8" FontSize="13"
                                            Click="ToggleActiveButton_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
