<Window x:Class="TempleLampSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="點燈管理系統 - 登入"
        Width="420"
        MinHeight="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頂部標題 -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource GoldDarkBrush}"
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Height="4" Background="{StaticResource GoldGradient}"/>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,20,0,16">
                    <TextBlock Text="&#x2726;" FontSize="30" Foreground="#FFD700" HorizontalAlignment="Center"/>
                    <TextBlock Text="點燈管理系統" FontSize="22" FontWeight="Bold"
                               Foreground="#FFD700" HorizontalAlignment="Center"
                               FontFamily="{StaticResource PrimaryFont}" Margin="0,6,0,0"/>
                    <TextBlock Text="工作人員登入" FontSize="13"
                               Foreground="#C9A96E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Row="2" Height="3" Background="{StaticResource GoldGradient}"/>
            </Grid>
        </Border>

        <!-- 登入表單 -->
        <StackPanel Grid.Row="1" Margin="40,30,40,20" VerticalAlignment="Center">

            <!-- 姓名 -->
            <TextBlock Text="姓名" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="NameTextBox"
                     FontSize="15"
                     Padding="10,8"
                     Margin="0,0,0,16"
                     KeyDown="InputBox_KeyDown"/>

            <!-- 密碼 -->
            <TextBlock Text="密碼" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <PasswordBox x:Name="PasswordBox"
                         FontSize="15"
                         Padding="10,8"
                         Margin="0,0,0,8"
                         KeyDown="InputBox_KeyDown"/>

            <!-- 狀態訊息（雲端同步中） -->
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="{StaticResource GoldDarkBrush}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"
                       Visibility="Collapsed"/>

            <!-- 錯誤訊息 -->
            <TextBlock x:Name="ErrorText"
                       Foreground="Red"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"
                       Visibility="Collapsed"/>

            <!-- 登入按鈕 -->
            <Button x:Name="LoginButton"
                    Content="登 入"
                    FontSize="16"
                    FontWeight="Bold"
                    Padding="0,12"
                    Style="{StaticResource PrimaryButton}"
                    Click="LoginButton_Click"/>

            <!-- 重試按鈕（雲端連線失敗時顯示） -->
            <Button x:Name="RetryButton"
                    Content="重新連線"
                    FontSize="14"
                    Padding="0,10"
                    Margin="0,8,0,0"
                    Visibility="Collapsed"
                    Click="RetryButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
