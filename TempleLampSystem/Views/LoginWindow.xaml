<Window x:Class="TempleLampSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="鎰翔科技 - 點燈管理系統"
        Width="440"
        MinHeight="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 頂部品牌區 - 鎰翔水墨殿堂 -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource GoldDarkBrush}"
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 頂部金飾線 -->
                <Border Height="4" Background="{StaticResource GoldGradient}"/>

                <!-- 品牌主體 -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="30,24,30,20">

                    <!-- 廟宇裝飾符號 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="&#x2726;" FontSize="14" Foreground="#9A7C2A" VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.7"/>
                        <TextBlock Text="&#x2726;" FontSize="20" Foreground="#C8A84B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="&#x2726;" FontSize="14" Foreground="#9A7C2A" VerticalAlignment="Center" Opacity="0.7"/>
                    </StackPanel>

                    <!-- 公司名稱 - 鎰翔科技 -->
                    <TextBlock Text="鎰翔科技"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#E5CA7A"
                               HorizontalAlignment="Center"
                               FontFamily="{StaticResource PrimaryFont}"/>

                    <!-- 品牌標語 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,16">
                        <TextBlock Text="─── " Foreground="#9A7C2A" FontSize="13" VerticalAlignment="Center" Opacity="0.6"/>
                        <TextBlock Text="科技如詩・為你譜寫"
                                   FontSize="13"
                                   Foreground="#A89060"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text=" ───" Foreground="#9A7C2A" FontSize="13" VerticalAlignment="Center" Opacity="0.6"/>
                    </StackPanel>

                    <!-- 分隔線 -->
                    <Border Height="1" Background="{StaticResource GoldGradient}" Opacity="0.4" Margin="20,0,20,14"/>

                    <!-- 系統名稱 -->
                    <TextBlock Text="點燈管理系統"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#C8A84B"
                               HorizontalAlignment="Center"
                               FontFamily="{StaticResource PrimaryFont}"/>
                    <TextBlock Text="工作人員登入"
                               FontSize="12"
                               Foreground="#6A5A40"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 底部金飾線 -->
                <Border Grid.Row="2" Height="3" Background="{StaticResource GoldGradient}"/>
            </Grid>
        </Border>

        <!-- 登入表單 -->
        <StackPanel Grid.Row="1" Margin="44,32,44,28" VerticalAlignment="Center">

            <!-- 姓名 -->
            <TextBlock Text="姓名" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="NameTextBox"
                     FontSize="15"
                     Padding="10,10"
                     Margin="0,0,0,18"
                     KeyDown="InputBox_KeyDown"/>

            <!-- 密碼 -->
            <TextBlock Text="密碼" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <PasswordBox x:Name="PasswordBox"
                         FontSize="15"
                         Padding="10,10"
                         Margin="0,0,0,10"
                         KeyDown="InputBox_KeyDown"/>

            <!-- 狀態訊息（雲端同步中） -->
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="{StaticResource GoldDarkBrush}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"
                       Visibility="Collapsed"/>

            <!-- 錯誤訊息 -->
            <TextBlock x:Name="ErrorText"
                       Foreground="#C62828"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,18"
                       Visibility="Collapsed"/>

            <!-- 登入按鈕 - 廟宇金 -->
            <Button x:Name="LoginButton"
                    Content="登　入"
                    FontSize="16"
                    FontWeight="Bold"
                    Padding="0,13"
                    Style="{StaticResource PrimaryButton}"
                    Click="LoginButton_Click"/>

            <!-- 重試按鈕 -->
            <Button x:Name="RetryButton"
                    Content="重新連線"
                    FontSize="14"
                    Padding="0,10"
                    Margin="0,8,0,0"
                    Visibility="Collapsed"
                    Click="RetryButton_Click"/>

            <!-- 版權標記 -->
            <TextBlock Text="© 鎰翔科技 版權所有"
                       FontSize="11"
                       Foreground="#8A7A60"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"
                       Opacity="0.7"/>
        </StackPanel>
    </Grid>
</Window>
