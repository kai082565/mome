<Window x:Class="TempleLampSystem.Views.FirstRunSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="鎰翔科技 - 初始設定"
        Width="440"
        Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}">

    <StackPanel Margin="0">
        <!-- 頂部品牌區 -->
        <Border Background="{StaticResource HeaderGradient}"
                BorderBrush="{StaticResource GoldDarkBrush}"
                BorderThickness="0,0,0,2"
                Margin="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Height="3" Background="{StaticResource GoldGradient}"/>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,18,0,14">
                    <TextBlock Text="&#x2726;" FontSize="20" Foreground="#C8A84B" HorizontalAlignment="Center"/>
                    <TextBlock Text="鎰翔科技" FontSize="22" FontWeight="Bold"
                               Foreground="#E5CA7A" HorizontalAlignment="Center"
                               FontFamily="{StaticResource PrimaryFont}" Margin="0,4,0,2"/>
                    <TextBlock Text="點燈管理系統 初始設定" FontSize="13"
                               Foreground="#8A7A60" HorizontalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Row="2" Height="2" Background="{StaticResource GoldGradient}"/>
            </Grid>
        </Border>

        <!-- 表單區 -->
        <StackPanel Margin="36,24,36,20">
            <TextBlock Text="歡迎使用點燈管理系統" FontSize="17" FontWeight="Bold"
                       Foreground="{StaticResource SecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="請建立第一個管理員帳號" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,22"/>

            <!-- 姓名 -->
            <TextBlock Text="管理員姓名" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="NameTextBox" FontSize="15" Padding="10,8" Margin="0,0,0,16"/>

            <!-- 密碼 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="密碼" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="（至少 4 個字元）" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
            </StackPanel>
            <PasswordBox x:Name="PasswordBox" FontSize="15" Padding="10,8" Margin="0,0,0,8"/>

            <!-- 確認密碼 -->
            <TextBlock Text="確認密碼" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <PasswordBox x:Name="ConfirmPasswordBox" FontSize="15" Padding="10,8" Margin="0,0,0,10"/>

            <!-- 錯誤訊息 -->
            <TextBlock x:Name="ErrorText" Foreground="#C62828" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,14" Visibility="Collapsed"/>

            <!-- 按鈕 -->
            <Button x:Name="CreateButton" Content="建立管理員帳號" FontSize="15" FontWeight="Bold"
                    Padding="0,12" Style="{StaticResource PrimaryButton}"
                    Click="CreateButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
