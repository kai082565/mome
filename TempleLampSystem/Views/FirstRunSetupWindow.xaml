<Window x:Class="TempleLampSystem.Views.FirstRunSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="初始設定 - 建立管理員帳號"
        Width="420"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}">

    <StackPanel Margin="36,28,36,20">
        <TextBlock Text="歡迎使用點燈管理系統" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource SecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
        <TextBlock Text="請建立第一個管理員帳號" FontSize="14"
                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>

        <!-- 姓名 -->
        <TextBlock Text="管理員姓名" FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
        <TextBox x:Name="NameTextBox" FontSize="15" Padding="10,8" Margin="0,0,0,16"/>

        <!-- 密碼 -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="密碼" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBlock Text="（至少 4 個字元）" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
        </StackPanel>
        <PasswordBox x:Name="PasswordBox" FontSize="15" Padding="10,8" Margin="0,0,0,8"/>

        <!-- 確認密碼 -->
        <TextBlock Text="確認密碼" FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
        <PasswordBox x:Name="ConfirmPasswordBox" FontSize="15" Padding="10,8" Margin="0,0,0,8"/>

        <!-- 錯誤訊息 -->
        <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="13"
                   HorizontalAlignment="Center" Margin="0,0,0,14" Visibility="Collapsed"/>

        <!-- 按鈕 -->
        <Button x:Name="CreateButton" Content="建立管理員帳號" FontSize="15" FontWeight="Bold"
                Padding="0,12" Style="{StaticResource PrimaryButton}"
                Click="CreateButton_Click"/>
    </StackPanel>
</Window>
